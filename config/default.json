{
  "discord": {
    "token": "${DISCORD_TOKEN}",
    "guildId": "${DISCORD_GUILD_ID}",
    "ownerId": "${DISCORD_OWNER_ID}",
    "announcementChannel": "${ANNOUNCEMENTS_CHANNEL}",
    "rulesChannel": "${RULES_CHANNEL}",
    "ownerRequestsChannel": "${OWNER_REQUESTS_CHANNEL}"
  },
  "loop": {
    "intervalMinutes": "${LOOP_INTERVAL_MINUTES}"
  },
  "llm": {
    "provider": "${LLM_PROVIDER}",
    "openrouter": {
      "apiKey": "${OPENROUTER_API_KEY}",
      "model": "${OPENROUTER_MODEL}",
      "site": "${OPENROUTER_SITE}",
      "appName": "${OPENROUTER_APP}"
    },
    "usage": {
      "maxCallsPerTick": "${LLM_MAX_CALLS_PER_TICK}",
      "cooldownMinutes": "${LLM_COOLDOWN_MINUTES}",
      "cooldownMinutesOn402": "${LLM_COOLDOWN_MINUTES_402}",
      "allowedAgents": "${LLM_ALLOWED_AGENTS}"
    }
  },
  "db": {
    "path": "${DB_PATH}"
  },
  "permissions": {
    "path": "config/permissions.json"
  }
}
